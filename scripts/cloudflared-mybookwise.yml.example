# Cloudflare 命名隧道配置（固定域名 mybookwise.xyz）
#
# 首次使用：
#   1. 复制本文件为 cloudflared-mybookwise.yml（同目录，已在 .gitignore）
#   2. 按 README「固定域名 mybookwise.xyz」完成 tunnel create / route dns
#   3. 将下面 tunnel 与 credentials-file 换成你的 UUID 与凭证路径
#
# 启动：powershell -File scripts/start_tunnel_named.ps1

tunnel: REPLACE_WITH_TUNNEL_UUID
credentials-file: C:\Users\YOUR_USER\.cloudflared\REPLACE_WITH_TUNNEL_UUID.json

ingress:
  - hostname: mybookwise.xyz
    service: http://127.0.0.1:8000
  - hostname: www.mybookwise.xyz
    service: http://127.0.0.1:8000
  - service: http_status:404
