# Normalize line endings across Windows / macOS / Linux.
* text=auto

# Source & config — LF (cross-platform standard)
*.py text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows-only scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — do not touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.pyc binary
*.sqlite3 binary
*.db binary
*.jar binary
*.apk binary
*.aab binary
*.woff binary
*.woff2 binary
